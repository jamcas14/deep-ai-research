# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.venv/
venv/

# uv: uv.lock IS committed for reproducibility (per uv docs).
# Don't add it here.

# Secrets
.env
.env.local
*.key
*.pem

# Corpus — gitignored by default; configurable via config/paths.yaml.
# The corpus is rebuildable from sources, so we don't track it in git.
corpus/

# But DO track the directory shape so cloned repos get the structure.
!corpus/.gitkeep

# Per-research-run scratch dirs — ephemeral
.claude/scratch/

# Per-machine state (Patch CC: usage snapshots from Stop hook)
.claude/state/

# Project-scoped settings — per-machine, may contain hooks/permissions
.claude/settings.local.json

# Eval run traces — keep _history.jsonl, archive everything else
evals/runs/*/
!evals/runs/_history.jsonl

# Reports — committable for audit trail; user choice. Keep them.
# (Reports stay tracked.)

# Daily digests (Patch BB) — terminal-friendly user-facing copy. The corpus
# version at corpus/digests/ is already gitignored via the corpus/ rule.
# Use directory-content pattern + negation so .gitkeep stays tracked.
digests/*
!digests/.gitkeep

# Build / test artifacts
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# OS
.DS_Store
Thumbs.db
