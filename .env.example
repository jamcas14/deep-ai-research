# Copy to .env and fill in. .env is gitignored.

# GitHub Personal Access Token — for authority engagement polling, GitHub MCP.
# Free. Create at: https://github.com/settings/tokens (scope: public_repo, read:user)
# Without this: GitHub API caps at 60 req/hr; with: 5000/hr.
GITHUB_TOKEN=

# HuggingFace token — for HF Daily Papers, model downloads.
# Free. Create at: https://huggingface.co/settings/tokens
HF_TOKEN=

# Reddit API credentials — for r/LocalLLaMA, r/MachineLearning ingestion.
# Free. Register an app at: https://www.reddit.com/prefs/apps (script type)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=dair:v0.1 (by u/your-username)

# Anthropic API key — OPTIONAL.
# The orchestrator runs in Claude Code under the $200 Max plan.
# Set this only if you want background ingestion summarization via Haiku
# (separate billing from Max).  Leave blank for the fully-free path
# (raw content stored without ingestion-time summarization).
ANTHROPIC_API_KEY=
